# ──────────────────────────────────────────
#  APPLICATION
# ──────────────────────────────────────────
APP_NAME="Financial Planning API"
APP_VERSION="1.0.0"
APP_ENV="development"          # development | staging | production
DEBUG=true

# ──────────────────────────────────────────
#  SERVER
# ──────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000
WORKERS=1                      # aumente em produção (recomendado: nCPU * 2 + 1)

# ──────────────────────────────────────────
#  DATABASE
# ──────────────────────────────────────────
# SQLite (desenvolvimento)
DATABASE_URL="sqlite://./data/financial.db"

# PostgreSQL (produção) — descomente e ajuste
# DATABASE_URL="postgres://user:password@db:5432/financial_db"

# ──────────────────────────────────────────
#  SEGURANÇA / JWT
# ──────────────────────────────────────────
SECRET_KEY="TROQUE_POR_UMA_CHAVE_FORTE_DE_64_CHARS_MINIMO"   # openssl rand -hex 32
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────────────────
#  CORS
# ──────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
ALLOWED_METHODS="GET,POST,PUT,PATCH,DELETE,OPTIONS"
ALLOWED_HEADERS="*"

# ──────────────────────────────────────────
#  RATE LIMITING
# ──────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ──────────────────────────────────────────
#  INTEGRAÇÕES EXTERNAS
# ──────────────────────────────────────────
ZILLOW_API_KEY=""
ZILLOW_API_URL="https://api.zillow.com/v2"

# ──────────────────────────────────────────
#  ENCRYPTION (SSN em repouso)
# ──────────────────────────────────────────
ENCRYPTION_KEY=""              # Fernet key — python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ──────────────────────────────────────────
#  LOGGING
# ──────────────────────────────────────────
LOG_LEVEL="INFO"               # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT="json"              # json | console
