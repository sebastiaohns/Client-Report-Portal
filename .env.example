# ══════════════════════════════════════════════
#  FinPlan — Monorepo Environment Variables
#  Copy to .env and fill in the values
# ══════════════════════════════════════════════

# ── Compose project name ─────────────────────
COMPOSE_PROJECT_NAME=finplan

# ── Backend ──────────────────────────────────
APP_NAME="Financial Planning API"
APP_VERSION="1.0.0"
APP_ENV="development"          # development | staging | production
DEBUG=true
WORKERS=1

# Database (SQLite for dev; PostgreSQL for prod)
DATABASE_URL="sqlite:///app/data/financial.db"
# DATABASE_URL="postgres://finplan:finplan_pass@db:5432/finplan_db"

# JWT — generate with: openssl rand -hex 32
SECRET_KEY="REPLACE_WITH_STRONG_KEY_MIN_32_CHARS_xxxxxxxxxxx"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — in production, point to the real domain
ALLOWED_ORIGINS="http://localhost"
ALLOWED_METHODS="GET,POST,PUT,PATCH,DELETE,OPTIONS"
ALLOWED_HEADERS="*"

RATE_LIMIT_PER_MINUTE=60

# Zillow integration
ZILLOW_API_KEY=""
ZILLOW_API_URL="https://api.zillow.com/v2"

# SSN encryption — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=""

LOG_LEVEL="INFO"
LOG_FORMAT="json"

# ── Frontend ─────────────────────────────────
# Injected into config.js by the nginx container entrypoint
# In dev: points to /api/v1 (proxied by nginx)
# In prod: can be the public API URL
API_URL="/api/v1"